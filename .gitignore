# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# pilot/cinematic draft renders — large media, never commit
/drafts/
/pilot/
/public/preview/
/public/videos/generated/
scripts/output/marketing/
scripts/output/instagram/
scripts/output/.pass*-snapshot/
scripts/output/.pre-pass*-snapshot/
scripts/output/.pre-repair/
scripts/output/.checkpoint*.json
__pycache__/
/tmp/
/tmp_screenshot.js

# credentials — NEVER commit
.google-veo-service-account.json
*-service-account.json
*credentials*.json
gcp-key*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# raw generation candidates/renders — selected winners live in public/ (back up externally; Gemini creds deleted)
scripts/output/vocab-candidates/
scripts/output/scenes-candidates/
scripts/output/veo-loops/
scripts/output/kuttan-pack/
scripts/output/videos/

# video render caches & per-project deps — regenerable, never commit (chunk V1-00)
videos/**/node_modules/
videos/**/renders/**
experiments/**/output/**
