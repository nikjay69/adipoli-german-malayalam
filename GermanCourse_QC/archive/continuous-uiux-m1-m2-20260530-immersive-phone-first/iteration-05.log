+def assert_hear_steps_are_one_tap_scene() -> None:
+    """Keep first-path listening from becoming a two-audio chore before the learner acts."""
+    pages = MISSION_PAGES + MODULE1_MISSION_PAGES
+    old_chore_copy = [
+        "Play the clips",
+        "First the examiner, then",
+        "Try this reply",
+        "Reply model",
+        "model answer",
+        "Full model answer",
+        "Polite words",
+    ]
+    for page in pages:
+        src = page.read_text(encoding="utf-8")
+        match = re.search(r"<HearStep(?P<block>.*?)\n\s*/>", src, re.S)
+        if not match:
+            fail(f"mission page missing HearStep: {page}")
+        block = match.group("block")
+        audio_count = block.count("{ src:")
+        if audio_count != 1:
+            fail(f"HearStep should require exactly one scene audio before action in {page.name}; found {audio_count}")
+        hits = [snippet for snippet in old_chore_copy if snippet in block]
+        if hits:
+            fail(f"HearStep reintroduced multi-clip/chore copy in {page.name}: {hits}")
+    print(f"one_tap_hear_steps={len(pages)}")
 
 
