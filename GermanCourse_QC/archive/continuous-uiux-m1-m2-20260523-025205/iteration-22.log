+import puppeteer from '/shared/german-course/node_modules/puppeteer/lib/esm/puppeteer/puppeteer.js';
+
+const BASE = 'http://127.0.0.1:3000';
+const browser = await puppeteer.launch({
+  headless: 'new',
+  executablePath: '/usr/bin/google-chrome',
+  args: ['--no-sandbox', '--disable-setuid-sandbox', '--disable-dev-shm-usage'],
+});
+try {
+  const page = await browser.newPage();
+  const logs = [];
+  page.on('console', (msg) => { if (msg.type() === 'error' || msg.type() === 'warning') logs.push(`${msg.type()}: ${msg.text()}`); });
+  page.on('pageerror', (err) => logs.push(`PAGEERROR: ${err.message}`));
+  await page.setViewport({ width: 390, height: 844, isMobile: true });
+  await page.evaluateOnNewDocument(() => {
+    window.localStorage.removeItem('adipoli:module2:completedMissions');
+    window.localStorage.setItem('adipoli:module1:completedMissions', JSON.stringify(['greetFrauWeber', 'pleaseThanks', 'politeExit']));
+  });
+  await page.goto(`${BASE}/learn/2`, { waitUntil: 'domcontentloaded', timeout: 45000 });
+  await new Promise((resolve) => setTimeout(resolve, 1400));
+  const before = await page.evaluate(() => ({
+    path: location.pathname,
+    bodyText: document.body.innerText,
+    nav: !!document.querySelector('nav'),
+    search: !!document.querySelector('[role="search"], input[placeholder*="Search"], button[aria-label*="search" i]'),
+    compactLinks: document.querySelectorAll('[aria-label="Compact Module 2 mission progress"] a').length,
+    mapOpen: !!document.querySelector('details[open]'),
+    primaryText: Array.from(document.querySelectorAll('a,button')).map((el) => el.textContent?.trim() || '').find((text) => text.includes('Start mission')) || '',
+    oldCrowding: ['Module 2 path', 'Your speaking mission sequence', 'Speaking path', 'Open mission map', 'Start: Tell the examiner your name'].filter((x) => document.body.innerText.includes(x)),
+  }));
+  const primary = await page.$('a[href="/missions/module-2/self-intro"]');
+  if (!primary) throw new Error('Missing primary /missions/module-2/self-intro link');
+  await primary.click();
+  await page.waitForFunction(() => location.pathname === '/missions/module-2/self-intro', { timeout: 12000 });
+  await new Promise((resolve) => setTimeout(resolve, 900));
+  const startButton = await page.$('button');
+  if (!startButton) throw new Error('Missing mission start button');
+  await startButton.click();
+  await new Promise((resolve) => setTimeout(resolve, 900));
+  const after = await page.evaluate(() => ({
+    path: location.pathname,
+    audioControls: document.querySelectorAll('audio[controls]').length,
+    heading: document.querySelector('h1')?.textContent?.trim() || '',
+  }));
+  await page.screenshot({ path: '/tmp/adipoli_iter22_learn2_mobile.png', fullPage: false });
+  console.log(JSON.stringify({ before, after, logs }, null, 2));
+  if (before.path !== '/learn/2') throw new Error(`Bad starting path: ${before.path}`);
+  if (before.nav || before.search) throw new Error('Focused /learn/2 should not show nav/search');
+  if (before.compactLinks !== 5) throw new Error(`Expected 5 compact mission links, got ${before.compactLinks}`);
+  if (before.mapOpen) throw new Error('Mission map should be collapsed by default');
+  if (!before.primaryText.includes('Start mission 2.1')) throw new Error(`Primary CTA not compact: ${before.primaryText}`);
+  if (before.oldCrowding.length) throw new Error(`Old crowding still visible: ${before.oldCrowding.join(', ')}`);
+  if (after.audioControls < 1) throw new Error('Native audio control not visible after mission start');
+  if (logs.length) throw new Error(`Console/page issues: ${logs.join(' | ')}`);
+} finally {
+  await browser.close();
+}
