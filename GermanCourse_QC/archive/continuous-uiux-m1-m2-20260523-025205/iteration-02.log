+const puppeteer = require('/shared/german-course/node_modules/puppeteer');
+
+(async () => {
+  const browser = await puppeteer.launch({
+    headless: 'new',
+    executablePath: '/usr/bin/google-chrome',
+    args: ['--no-sandbox'],
+  });
+  const page = await browser.newPage();
+  const errors = [];
+  page.on('console', msg => {
+    if (['error', 'warning'].includes(msg.type())) errors.push(`${msg.type()}: ${msg.text()}`);
+  });
+  page.on('pageerror', err => errors.push(`pageerror: ${err.message}`));
+
+  const base = 'http://127.0.0.1:3000';
+  async function settle() { await new Promise(resolve => setTimeout(resolve, 900)); }
+
+  await page.goto(`${base}/learn`, { waitUntil: 'domcontentloaded' });
+  await page.evaluate(() => localStorage.removeItem('adipoli:module1:completedMissions'));
+  await page.reload({ waitUntil: 'domcontentloaded' });
+  await settle();
+  const freshLearn = await page.evaluate(() => ({
+    title: document.querySelector('h1')?.textContent?.trim(),
+    hrefs: Array.from(document.querySelectorAll('a')).map(a => a.getAttribute('href')).filter(Boolean).slice(0, 8),
+    text: document.body.innerText.slice(0, 900),
+  }));
+  if (!freshLearn.hrefs.includes('/missions/module-1/greet-frau-weber')) throw new Error(`/learn fresh did not point to Mission 1.1: ${JSON.stringify(freshLearn)}`);
+
+  await page.evaluate(() => localStorage.setItem('adipoli:module1:completedMissions', JSON.stringify(['greetFrauWeber'])));
+  await page.goto(`${base}/learn`, { waitUntil: 'domcontentloaded' });
+  await settle();
+  const partialLearn = await page.evaluate(() => ({
+    title: document.querySelector('h1')?.textContent?.trim(),
+    hrefs: Array.from(document.querySelectorAll('a')).map(a => a.getAttribute('href')).filter(Boolean).slice(0, 8),
+    hasPoliteOutput: document.body.innerText.includes('Vielen Dank. Auf Wiedersehen.'),
+  }));
+  if (!partialLearn.hrefs.includes('/missions/module-1/polite-exit') || !partialLearn.hasPoliteOutput) throw new Error(`/learn partial did not point to Mission 1.2: ${JSON.stringify(partialLearn)}`);
+  await page.click('a[href="/missions/module-1/polite-exit"]');
+  await settle();
+  if (new URL(page.url()).pathname !== '/missions/module-1/polite-exit') throw new Error(`click from /learn went to ${page.url()}`);
+
+  await page.goto(`${base}/learn/1`, { waitUntil: 'domcontentloaded' });
+  await page.evaluate(() => localStorage.setItem('adipoli:module1:completedMissions', JSON.stringify(['greetFrauWeber'])));
+  await page.reload({ waitUntil: 'domcontentloaded' });
+  await settle();
+  const module1 = await page.evaluate(() => ({
+    ctaText: Array.from(document.querySelectorAll('a')).find(a => a.getAttribute('href') === '/missions/module-1/polite-exit')?.textContent?.replace(/\s+/g, ' ').trim(),
+    bodyHasProgress: document.body.innerText.includes('1/2 complete'),
+    bodyHasPolite: document.body.innerText.includes('Leave the room politely'),
+  }));
+  if (!module1.ctaText || !module1.bodyHasProgress || !module1.bodyHasPolite) throw new Error(`/learn/1 partial state weak: ${JSON.stringify(module1)}`);
+
+  await page.goto(`${base}/missions/module-1/polite-exit`, { waitUntil: 'domcontentloaded' });
+  await settle();
+  await page.click('button');
+  await settle();
+  const missionStep = await page.evaluate(() => ({
+    path: location.pathname,
+    hasAudio: document.querySelectorAll('audio[controls]').length,
+    text: document.body.innerText.slice(0, 800),
+  }));
+  if (missionStep.path !== '/missions/module-1/polite-exit' || missionStep.hasAudio < 2 || !missionStep.text.includes('Hear the exit toolkit')) {
+    throw new Error(`polite-exit first transition/audio failed: ${JSON.stringify(missionStep)}`);
+  }
+
+  const audioRes = await page.evaluate(async () => {
+    const res = await fetch('/audio/tts/v1-4-1/v1-4-1-line-0.mp3');
+    return { status: res.status, type: res.headers.get('content-type'), len: +(res.headers.get('content-length') || 0) };
+  });
+  if (audioRes.status !== 200 || !audioRes.type.startsWith('audio/')) throw new Error(`audio fetch failed: ${JSON.stringify(audioRes)}`);
+
+  const realErrors = errors.filter(e => !e.includes('Download the React DevTools'));
+  await browser.close();
+  console.log(JSON.stringify({ freshLearn, partialLearn, module1, missionStep, audioRes, errors: realErrors }, null, 2));
+  if (realErrors.length) throw new Error(`browser console errors/warnings: ${realErrors.join(' | ')}`);
+})();
