+'use client';
+
+import { useEffect, useMemo, useState } from 'react';
+import Link from 'next/link';
+import { ArrowRight, ChevronLeft, DoorOpen, Sparkles, Trophy } from 'lucide-react';
+import {
+  BuilderStep,
+  HearStep,
+  MissionIntro,
+  MissionShell,
+  NativeAudio,
+  PremiumCard,
+  PrimaryButton,
+  ProductionStep,
+  RecognitionStep,
+  RepairStep,
+  SecondaryLink,
+  normalizeMissionAnswer,
+  useMissionStepForQA,
+} from '@/app/missions/module-2/_components/MissionUI';
+import { module1MissionAudio, module1MissionById, writeCompletedModule1Mission } from '@/lib/missions/module1';
+
+const mission = module1MissionById.politeExit;
+const missionSteps = mission.steps;
+const audioSources = module1MissionAudio.politeExit;
+
+const exitOptions = [
+  { id: 'formal-exit', title: 'Vielen Dank. Auf Wiedersehen.', subtitle: 'Safe, polite classroom/office exit.' },
+  { id: 'bedtime', title: 'Danke. Gute Nacht.', subtitle: 'Only when bedtime is the context.' },
+  { id: 'phone', title: 'Danke. Auf Wiederhören.', subtitle: 'Phone goodbye, not face to face.' },
+];
+
+const builderWords = ['Vielen', 'Dank', 'Auf', 'Wiedersehen'];
+const builderBank = ['Vielen', 'Dank', 'Bitte', 'Auf', 'Wiedersehen', 'Gute', 'Nacht'];
+const correctExit = 'Vielen Dank Auf Wiedersehen';
+
+export default function Module1PoliteExitMissionPage() {
+  const [step, setStep] = useMissionStepForQA(0, missionSteps.length - 1);
+  const [heard, setHeard] = useState(false);
+  const [recognition, setRecognition] = useState<string | null>(null);
+  const [selectedWords, setSelectedWords] = useState<string[]>([]);
+  const [spokenChecked, setSpokenChecked] = useState(false);
+  const [typedAnswer, setTypedAnswer] = useState('');
+  const [repairChoice, setRepairChoice] = useState<string | null>(null);
+
+  const builtExit = selectedWords.join(' ');
+  const builderCorrect = builtExit === correctExit;
+  const recognitionCorrect = recognition === 'formal-exit';
+  const typedNormalized = normalizeMissionAnswer(typedAnswer);
+  const typedIsStrong = typedNormalized.includes('vielen dank') && typedNormalized.includes('auf wiedersehen');
+  const repairCorrect = repairChoice === 'auf-wiedersehen';
+
+  useEffect(() => {
+    if (step === missionSteps.length - 1) {
+      writeCompletedModule1Mission(mission.id);
+    }
+  }, [step]);
+
+  const canContinue = useMemo(() => {
+    switch (step) {
+      case 1:
+        return heard;
+      case 2:
+        return recognitionCorrect;
+      case 3:
+        return builderCorrect;
+      case 4:
+        return spokenChecked && typedIsStrong;
+      case 5:
+        return repairCorrect;
+      default:
+        return true;
+    }
+  }, [builderCorrect, heard, recognitionCorrect, repairCorrect, spokenChecked, step, typedIsStrong]);
+
+  const next = () => setStep((value) => Math.min(value + 1, missionSteps.length - 1));
+  const back = () => setStep((value) => Math.max(value - 1, 0));
+
