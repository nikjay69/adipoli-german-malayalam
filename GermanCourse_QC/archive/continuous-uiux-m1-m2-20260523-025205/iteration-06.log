+const puppeteer = require('/shared/german-course/node_modules/puppeteer');
+(async () => {
+  const browser = await puppeteer.launch({ headless: 'new', executablePath: '/usr/bin/google-chrome', args: ['--no-sandbox'] });
+  const page = await browser.newPage();
+  const errors = [];
+  const consoleMessages = [];
+  page.on('pageerror', err => errors.push(err.stack || err.message || String(err)));
+  page.on('console', msg => {
+    if (['error', 'warning'].includes(msg.type())) consoleMessages.push(`${msg.type()}: ${msg.text()}`);
+  });
+  await page.goto('http://127.0.0.1:3000/', { waitUntil: 'domcontentloaded', timeout: 30000 });
+  await page.evaluate(() => {
+    localStorage.setItem('adipoli:intro:seen', 'true');
+    localStorage.setItem('adipoli:module1:completedMissions', JSON.stringify(['greetFrauWeber','pleaseThanks','politeExit']));
+  });
+  await page.reload({ waitUntil: 'domcontentloaded', timeout: 30000 });
+  await new Promise(r => setTimeout(r, 1500));
+  const home = await page.evaluate(() => ({
+    path: location.pathname,
+    text: document.body.innerText,
+    mainCount: document.querySelectorAll('main').length,
+    navCount: document.querySelectorAll('nav').length,
+    searchCount: document.querySelectorAll('input[type="search"]').length,
+    link: Array.from(document.querySelectorAll('a')).find(a => /Begin the speaking path|Start Module 2 speaking|Start Mission/.test(a.innerText))?.href || null,
+  }));
+  if (!home.link) throw new Error('No primary link found on home');
+  await page.click('a[href="/missions/module-2/self-intro"], a[href="/missions/module-1/greet-frau-weber"]');
+  await new Promise(r => setTimeout(r, 1000));
+  const afterClick = await page.evaluate(() => ({ path: location.pathname, text: document.body.innerText.slice(0, 500) }));
+  await browser.close();
+  console.log(JSON.stringify({ home, afterClick, errors, consoleMessages }, null, 2));
+})();
