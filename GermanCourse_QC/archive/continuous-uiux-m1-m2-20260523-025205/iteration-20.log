+await new Promise((resolve) => setTimeout(resolve, 1000));
+const visual = await page.evaluate(() => ({
+  path: location.pathname,
+  bodyText: document.body.innerText.slice(0, 1400),
+  visibleNextColon: [...document.querySelectorAll('body *')].filter((el) => {
+    const rect = el.getBoundingClientRect();
+    const style = getComputedStyle(el);
+    return rect.width > 0 && rect.height > 0 && style.visibility !== 'hidden' && style.display !== 'none' && /Next:/.test(el.textContent || '');
+  }).length,
+  compactM1: !!document.querySelector('[aria-label="Module 1 compact win progress"]'),
+  module2CardHref: [...document.querySelectorAll('a')].map((a) => a.getAttribute('href')).find((href) => href === '/learn/2') || null,
+}));
+if (visual.visibleNextColon !== 0) throw new Error(`visible Next: clutter remains: ${visual.visibleNextColon}`);
+if (!visual.compactM1) throw new Error('compact M1 win progress missing');
+if (visual.module2CardHref !== '/learn/2') throw new Error('M1 final does not expose /learn/2 next card');
+await page.click('a[href="/learn/2"]');
+await page.waitForFunction(() => location.pathname === '/learn/2', { timeout: 10000 });
+await page.waitForSelector('a[href="/missions/module-2/self-intro"]', { timeout: 10000 });
