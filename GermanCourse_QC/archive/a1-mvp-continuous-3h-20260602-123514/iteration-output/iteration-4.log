+'use client';
+
+import Link from 'next/link';
+import { useState } from 'react';
+import { ArrowRight } from 'lucide-react';
+import {
+  ConversationRepairStep,
+  MissionShell,
+  PremiumCard,
+  useMissionStepForQA,
+} from '@/app/missions/module-2/_components/MissionUI';
+import { module1GermanSoundsPractice } from '@/lib/missions/module1Practice';
+
+const practice = module1GermanSoundsPractice;
+const missionSteps = ['Sound + repair'];
+const focusChoices = ['ch / sch', 'w / v', 'ä ö ü'];
+
+export default function Module1GermanSoundsPracticePage() {
+  const [step] = useMissionStepForQA(0, missionSteps.length - 1);
+  const [repairChoice, setRepairChoice] = useState<string | null>(null);
+  const [focus, setFocus] = useState<string | null>(null);
+
+  const repairCorrect = repairChoice === practice.repair.correctChoiceId;
+
+  return (
+    <MissionShell currentStep={step} steps={missionSteps} railLabel="Module 1 · German sounds" tone="green">
+      <PremiumCard>
+        {step === 0 && (
+          <>
+            <ConversationRepairStep
+              title="ich ≠ isch"
+              hideTitle
+              sceneLabel="Kerala pronunciation drill"
+              sceneVisualVariant="ai-study"
+              speakerName={practice.scene.speakerName}
+              speakerLine={practice.scene.speakerLine}
+              learnerName="You"
+              learnerLine={practice.outputLines[0]}
+              audioSrc={practice.scene.audioSrc}
+              audioLabel="Sound line"
+              options={practice.repair.options}
+              value={repairChoice}
+              onChange={setRepairChoice}
+              isCorrect={repairCorrect}
+              wrongFeedback={practice.repair.wrongFeedback}
+              correctFeedback={practice.repair.correctFeedback}
+              cta={<>Lock sound contrast <ArrowRight className="h-5 w-5" /></>}
+              onContinue={() => {}}
+              turnCue={practice.scene.turnCue}
+            />
+
+            {repairCorrect && (
+              <section
+                className="mt-5 rounded-[1.5rem] border border-white/12 bg-white/[0.055] p-5"
+                data-testid="lesson-3-sounds-micro-check-card"
+                aria-label="Lesson 3 German sounds micro-check and recovery"
+              >
+                <div className="grid gap-4 lg:grid-cols-[0.8fr_1fr] lg:items-start">
+                  <div className="rounded-[1.35rem] border border-[#3fbf75]/25 bg-[#3fbf75]/12 p-5">
+                    <p className="text-sm font-black text-[#bcf7d0]">Sound contrast locked.</p>
+                    <p className="mt-2 text-2xl font-black">ich · schön · Weber · Tschüss</p>
+                    <p className="mt-2 text-sm font-semibold text-white/66">Shadow slowly. Accent perfection is not the goal; being understood is.</p>
+                  </div>
+
+                  <div className="rounded-[1.35rem] border border-[#f1d27a]/18 bg-[#f1d27a]/8 p-5">
+                    <p className="text-sm font-black text-[#f1d27a]">Hardest sound</p>
+                    <div className="mt-3 flex flex-wrap gap-2" role="group" aria-label="Choose the hardest German sound">
+                      {focusChoices.map((item) => {
+                        const selected = focus === item;
+                        return (
+                          <button
+                            key={item}
+                            type="button"
+                            onClick={() => setFocus(item)}
+                            className={`rounded-full border px-4 py-3 text-sm font-black transition active:scale-[0.98] ${
+                              selected
+                                ? 'border-[#f1d27a] bg-[#f1d27a]/18 text-[#f8dda0]'
+                                : 'border-white/12 bg-white/[0.055] text-white/82'
