+'use client';
+
+import { useMemo, useState } from 'react';
+import Link from 'next/link';
+import { ArrowRight, CheckCircle2, RotateCcw } from 'lucide-react';
+import {
+  MissionShell,
+  PremiumCard,
+  PrimaryButton,
+  SecondaryActionButton,
+} from '@/app/missions/module-2/_components/MissionUI';
+import {
+  MODULE1_CHECKPOINT_RESULT_STORAGE_KEY,
+  module1CheckpointRecoveryCards,
+  module1CheckpointSections,
+  scoreModule1Checkpoint,
+  type Module1CheckpointItem,
+} from '@/lib/missions/module1Checkpoint';
+
+const steps = ['Closed checkpoint'];
+
+function saveCheckpointResult(passedItemIds: string[]) {
+  if (typeof window === 'undefined') return;
+  const score = scoreModule1Checkpoint(passedItemIds);
+  window.localStorage.setItem(
+    MODULE1_CHECKPOINT_RESULT_STORAGE_KEY,
+    JSON.stringify({
+      passedItemIds,
+      earnedPoints: score.earnedPoints,
+      totalPoints: score.totalPoints,
+      percent: score.percent,
+      state: score.state,
+      failedTags: score.failedTags,
+      savedAt: new Date().toISOString(),
+    })
+  );
+  window.dispatchEvent(new CustomEvent('module1-checkpoint-scored', { detail: score }));
+}
+
+function itemModeLabel(item: Module1CheckpointItem) {
+  if (item.mode === 'listen') return 'Hear';
+  if (item.mode === 'speak') return 'Say';
+  if (item.mode === 'match') return 'Match';
+  if (item.mode === 'write') return 'Write';
+  return 'Choose';
+}
+
+export default function Module1CheckpointPage() {
+  const [passedItemIds, setPassedItemIds] = useState<string[]>([]);
+  const [saved, setSaved] = useState(false);
+  const score = useMemo(() => scoreModule1Checkpoint(passedItemIds), [passedItemIds]);
+  const selectedTags = new Set(score.failedTags);
+  const recoveryCards = module1CheckpointRecoveryCards.filter((card) => selectedTags.has(card.weaknessTag)).slice(0, 3);
+
+  const toggleItem = (itemId: string) => {
+    setSaved(false);
+    setPassedItemIds((current) => (
+      current.includes(itemId) ? current.filter((id) => id !== itemId) : [...current, itemId]
+    ));
+  };
+
+  const markAll = () => {
+    setSaved(false);
+    setPassedItemIds(module1CheckpointSections.flatMap((section) => section.items.map((item) => item.id)));
+  };
+
+  const reset = () => {
+    setSaved(false);
+    setPassedItemIds([]);
+  };
+
+  const save = () => {
+    saveCheckpointResult(passedItemIds);
+    setSaved(true);
+  };
+
+  return (
+    <MissionShell currentStep={0} steps={steps} railLabel="Module 1 · Closed checkpoint" tone="green">
