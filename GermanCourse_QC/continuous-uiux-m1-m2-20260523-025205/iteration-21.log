@@ -0,0 +1,44 @@
+import puppeteer from 'puppeteer';
+const BASE = 'http://127.0.0.1:3000';
+const browser = await puppeteer.launch({headless: 'new', executablePath: '/usr/bin/google-chrome', args: ['--no-sandbox', '--disable-setuid-sandbox', '--disable-dev-shm-usage']});
+try {
+  const page = await browser.newPage();
+  const consoleErrors = [];
+  page.on('console', (msg) => { if (msg.type() === 'error') consoleErrors.push(msg.text()); });
+  page.on('pageerror', err => consoleErrors.push(err.message));
+  await page.setViewport({width: 390, height: 844, isMobile: true});
+  await page.evaluateOnNewDocument(() => {
+    window.localStorage.removeItem('adipoli:module2:completedMissions');
+  });
+  await page.goto(`${BASE}/learn/2`, {waitUntil: 'domcontentloaded', timeout: 45000});
+  await new Promise(r => setTimeout(r, 1400));
+  const before = await page.evaluate(() => ({
+    path: location.pathname,
+    text: document.body.innerText,
+    nav: !!document.querySelector('nav'),
+    search: !!document.querySelector('[role="search"], input[placeholder*="Search"], button[aria-label*="search" i]'),
+    compactDots: document.querySelectorAll('[aria-label="Compact Module 2 mission progress"] a').length,
+    mapOpen: document.querySelector('details')?.hasAttribute('open') ?? null,
+    primary: Array.from(document.querySelectorAll('a,button')).map(el => ({text: el.innerText.trim(), href: el.href || '', top: Math.round(el.getBoundingClientRect().top), left: Math.round(el.getBoundingClientRect().left), width: Math.round(el.getBoundingClientRect().width), height: Math.round(el.getBoundingClientRect().height)})).filter(x => x.text || x.href).slice(0, 18),
+  }));
+  const target = Array.from(await page.$$('a')).find(async a => true);
+  const primaryLink = await page.$('a[href="/missions/module-2/self-intro"]');
+  if (!primaryLink) throw new Error('primary Module 2 mission link missing');
+  await primaryLink.click();
+  await page.waitForFunction(() => location.pathname === '/missions/module-2/self-intro', {timeout: 10000});
+  await new Promise(r => setTimeout(r, 800));
+  const after = await page.evaluate(() => ({
+    path: location.pathname,
+    nativeAudioCount: document.querySelectorAll('audio[controls]').length,
+    text: document.body.innerText.slice(0, 1000),
+  }));
+  console.log(JSON.stringify({before: {...before, text: before.text.slice(0, 1800)}, after, consoleErrors: consoleErrors.filter(line => !line.includes('favicon') && !line.includes('404'))}, null, 2));
+  await page.screenshot({path: '/tmp/adipoli_learn2_after_patch.png', fullPage: false});
+  if (before.nav || before.search) throw new Error('focused /learn/2 should hide nav/search');
+  if (before.compactDots !== 5) throw new Error(`expected 5 compact dots, got ${before.compactDots}`);
+  if (before.mapOpen) throw new Error('mission map should be collapsed by default');
+  if (after.path !== '/missions/module-2/self-intro') throw new Error(`wrong click path ${after.path}`);
+  if (consoleErrors.filter(line => !line.includes('favicon') && !line.includes('404')).length) throw new Error('console errors present');
+} finally {
+  await browser.close();
+}
