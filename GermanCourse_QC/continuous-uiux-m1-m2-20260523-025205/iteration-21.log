@@ -0,0 +1,32 @@
+import puppeteer from '/shared/german-course/node_modules/puppeteer/lib/esm/puppeteer/puppeteer.js';
+const browser = await puppeteer.launch({headless: 'new', executablePath: '/usr/bin/google-chrome', args: ['--no-sandbox', '--disable-setuid-sandbox', '--disable-dev-shm-usage']});
+try {
+  const page = await browser.newPage();
+  const errors = [];
+  page.on('console', (msg) => { if (msg.type() === 'error') errors.push(msg.text()); });
+  page.on('pageerror', err => errors.push(err.message));
+  await page.setViewport({width: 390, height: 844, isMobile: true});
+  await page.goto('http://127.0.0.1:3000/learn/2', {waitUntil: 'domcontentloaded', timeout: 45000});
+  await new Promise(r => setTimeout(r, 1000));
+  await page.click('a[href="/missions/module-2/self-intro"]');
+  await page.waitForFunction(() => location.pathname === '/missions/module-2/self-intro', {timeout: 10000});
+  await new Promise(r => setTimeout(r, 700));
+  const clicked = await page.evaluate(() => {
+    const button = Array.from(document.querySelectorAll('button')).find((el) => el.innerText.includes('Start mission'));
+    button?.click();
+    return !!button;
+  });
+  if (!clicked) throw new Error('Start mission button not found');
+  await new Promise(r => setTimeout(r, 800));
+  const state = await page.evaluate(() => ({
+    path: location.pathname,
+    text: document.body.innerText.slice(0, 1200),
+    audioCount: document.querySelectorAll('audio[controls]').length,
+    buttons: Array.from(document.querySelectorAll('button')).map(b => b.innerText.trim()).filter(Boolean).slice(0, 10),
+  }));
+  console.log(JSON.stringify({state, consoleErrors: errors.filter(line => !line.includes('favicon') && !line.includes('404'))}, null, 2));
+  if (state.audioCount < 1) throw new Error('native audio controls did not appear after starting mission');
+  if (errors.filter(line => !line.includes('favicon') && !line.includes('404')).length) throw new Error('console errors present');
+} finally {
+  await browser.close();
+}

