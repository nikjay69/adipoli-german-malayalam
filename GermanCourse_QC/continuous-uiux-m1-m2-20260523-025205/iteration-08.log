+import puppeteer from '/shared/german-course/node_modules/puppeteer/lib/esm/puppeteer/puppeteer.js';
+
+const browser = await puppeteer.launch({
+  headless: 'new',
+  executablePath: '/usr/bin/google-chrome',
+  args: ['--no-sandbox'],
+});
+
+const page = await browser.newPage();
+const logs = [];
+const errors = [];
+page.on('console', (msg) => logs.push(`${msg.type()}: ${msg.text()}`));
+page.on('pageerror', (err) => errors.push(err?.stack || err?.message || String(err)));
+
+async function check(url, expectedSnippet, forbiddenSnippet) {
+  await page.goto('http://127.0.0.1:3000/', { waitUntil: 'domcontentloaded', timeout: 30000 });
+  await page.evaluate(() => {
+    localStorage.removeItem('adipoli:module1:completedMissions');
+    localStorage.removeItem('adipoli:module2:completedMissions');
+  });
+  await page.goto(url, { waitUntil: 'domcontentloaded', timeout: 30000 });
+  await new Promise((resolve) => setTimeout(resolve, 1200));
+  const text = await page.evaluate(() => document.body.innerText);
+  if (!text.includes(expectedSnippet)) {
+    throw new Error(`Missing expected snippet ${expectedSnippet} at ${url}\n${text.slice(0, 1200)}`);
+  }
+  if (text.includes(forbiddenSnippet)) {
+    throw new Error(`Found forbidden snippet ${forbiddenSnippet} at ${url}\n${text.slice(0, 1200)}`);
+  }
+  return text.slice(0, 900);
+}
+
