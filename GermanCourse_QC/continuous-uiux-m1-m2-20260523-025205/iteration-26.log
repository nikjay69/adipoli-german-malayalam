+async function inspectBuilderStep(page, route, name, sequence, expectedSentence) {
+  await page.setViewport({ width: 390, height: 844, deviceScaleFactor: 2, isMobile: true });
+  await page.goto(`${BASE_URL}${route}?adipoliQa=1&adipoliQaStep=3`, { waitUntil: 'domcontentloaded', timeout: 45000 });
+  await page.waitForSelector('[data-testid="builder-word-bank"]', { timeout: 15000 });
+  await new Promise((resolve) => setTimeout(resolve, 250));
+
+  const before = await page.evaluate(() => ({
+    nav: Boolean(document.querySelector('nav')),
+    search: Boolean(document.querySelector('[role="search"], input[type="search"]')),
+    scrollWidth: document.documentElement.scrollWidth,
+    innerWidth: window.innerWidth,
+    chipCount: document.querySelectorAll('[data-testid="builder-chip"]').length,
+    slotCount: document.querySelectorAll('[data-testid="builder-slot"]').length,
+    builtText: document.querySelector('[data-testid="builder-built-sentence"]')?.textContent?.trim() ?? '',
+    builderCorrect: document.querySelector('[data-testid="builder-built-sentence"]')?.getAttribute('data-builder-correct'),
+    bodyStart: document.body.innerText.slice(0, 500),
+  }));
+  if (before.nav || before.search) throw new Error(`${name}: builder QA chrome regression nav=${before.nav} search=${before.search}`);
+  if (before.scrollWidth > before.innerWidth + 1) throw new Error(`${name}: builder QA overflow ${before.scrollWidth} > ${before.innerWidth}`);
+  if (before.chipCount < sequence.length || before.slotCount !== sequence.length) throw new Error(`${name}: builder chip/slot count wrong: ${JSON.stringify(before)}`);
+  if (before.builderCorrect !== 'false') throw new Error(`${name}: builder unexpectedly correct before interaction: ${JSON.stringify(before)}`);
+
+  for (const [index, word] of sequence.entries()) {
+    const clickResult = await page.evaluate((chipWord) => {
+      const buttons = Array.from(document.querySelectorAll('[data-testid="builder-chip"]'));
+      const button = buttons.find((candidate) => candidate.dataset.builderChip === chipWord && !candidate.disabled);
+      if (!button) {
+        return {
+          ok: false,
+          available: buttons.map((candidate) => ({
+            chip: candidate.dataset.builderChip,
+            state: candidate.dataset.builderState,
+            disabled: candidate.disabled,
+            text: candidate.textContent?.trim(),
+          })),
+        };
+      }
+      button.click();
+      return { ok: true, chip: button.dataset.builderChip, index: button.dataset.builderIndex };
+    }, word);
+    if (!clickResult.ok) throw new Error(`${name}: could not click builder chip ${word} at position ${index}: ${JSON.stringify(clickResult)}`);
+    await page.waitForFunction((filledCount) => {
+      return Array.from(document.querySelectorAll('[data-testid="builder-slot"]')).filter((slot) => slot.getAttribute('data-builder-slot-filled') === 'true').length >= filledCount;
+    }, { timeout: 5000 }, index + 1);
+  }
+
+  const after = await page.evaluate(() => {
+    const built = document.querySelector('[data-testid="builder-built-sentence"]');
+    const actionButton = Array.from(document.querySelectorAll('button')).find((button) => !button.disabled && /(say|perform|write|type)/i.test(button.textContent ?? ''));
+    return {
+      builtText: built?.textContent?.trim().replace(/\s+/g, ' ') ?? '',
+      builderCorrect: built?.getAttribute('data-builder-correct'),
+      filledSlots: Array.from(document.querySelectorAll('[data-testid="builder-slot"]')).filter((slot) => slot.getAttribute('data-builder-slot-filled') === 'true').length,
+      placedChipCount: Array.from(document.querySelectorAll('[data-testid="builder-chip"]')).filter((chip) => chip.getAttribute('data-builder-state') === 'placed').length,
+      actionButtonText: actionButton?.textContent?.trim() ?? '',
+      actionButtonDisabled: actionButton?.disabled ?? true,
+    };
+  });
+  if (after.builtText !== expectedSentence || after.builderCorrect !== 'true' || after.filledSlots !== sequence.length) {
+    throw new Error(`${name}: builder did not reach correct sentence: ${JSON.stringify(after)}`);
+  }
+  if (!after.actionButtonText || after.actionButtonDisabled) {
+    throw new Error(`${name}: builder continue CTA did not enable: ${JSON.stringify(after)}`);
+  }
+  console.log(`builder_clicks[${name}]=PASS chips=${sequence.length} built="${after.builtText}" cta="${after.actionButtonText}"`);
+}
+
