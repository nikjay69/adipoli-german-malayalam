+  HearStep,
+  MissionIntro,
+  MissionShell,
+  NativeAudio,
+  PremiumCard,
+  PrimaryButton,
+  ProductionStep,
+  RecognitionStep,
+  RepairStep,
+  SecondaryLink,
+  normalizeMissionAnswer,
+  useMissionStepForQA,
+} from '@/app/missions/module-2/_components/MissionUI';
+import { module1MissionAudio, module1MissionById, writeCompletedModule1Mission } from '@/lib/missions/module1';
+
+const mission = module1MissionById.greetFrauWeber;
+const missionSteps = mission.steps;
+const audioSources = module1MissionAudio.greetFrauWeber;
+
+const greetingOptions = [
+  { id: 'guten-morgen', title: 'Guten Morgen', subtitle: 'Safe for a morning class.' },
+  { id: 'gute-nacht', title: 'Gute Nacht', subtitle: 'Wrong time: this means good night.' },
+  { id: 'tschuss', title: 'Tschüss', subtitle: 'Casual goodbye, not a first greeting.' },
+];
+
+const builderWords = ['Guten', 'Morgen', 'Frau', 'Weber'];
+const builderBank = ['Guten', 'Morgen', 'Hallo', 'Frau', 'Weber', 'Tschüss'];
+const correctBuiltGreeting = 'Guten Morgen Frau Weber';
+
+export default function Module1GreetingMissionPage() {
+  const [step, setStep] = useMissionStepForQA(0, missionSteps.length - 1);
+  const [heard, setHeard] = useState(false);
+  const [recognition, setRecognition] = useState<string | null>(null);
+  const [selectedWords, setSelectedWords] = useState<string[]>([]);
+  const [spokenChecked, setSpokenChecked] = useState(false);
+  const [typedAnswer, setTypedAnswer] = useState('');
+  const [repairChoice, setRepairChoice] = useState<string | null>(null);
+
+  const builtGreeting = selectedWords.join(' ');
+  const builderCorrect = builtGreeting === correctBuiltGreeting;
+  const recognitionCorrect = recognition === 'guten-morgen';
+  const typedNormalized = normalizeMissionAnswer(typedAnswer);
+  const typedIsStrong = typedNormalized.includes('guten morgen') && typedNormalized.includes('ich lerne deutsch');
+  const repairCorrect = repairChoice === 'guten-morgen';
+
+  useEffect(() => {
+    if (step === missionSteps.length - 1) {
+      writeCompletedModule1Mission(mission.id);
+    }
+  }, [step]);
+
+  const canContinue = useMemo(() => {
+    switch (step) {
+      case 1:
+        return heard;
+      case 2:
+        return recognitionCorrect;
+      case 3:
+        return builderCorrect;
+      case 4:
+        return spokenChecked && typedIsStrong;
+      case 5:
+        return repairCorrect;
+      default:
+        return true;
+    }
+  }, [builderCorrect, heard, recognitionCorrect, repairCorrect, spokenChecked, step, typedIsStrong]);
+
+  const next = () => setStep((value) => Math.min(value + 1, missionSteps.length - 1));
+  const back = () => setStep((value) => Math.max(value - 1, 0));
+
