+const puppeteer = require('/shared/german-course/node_modules/puppeteer');
+(async () => {
+  const browser = await puppeteer.launch({headless:'new', executablePath:'/usr/bin/google-chrome', args:['--no-sandbox']});
+  const page = await browser.newPage();
+  const errors = [];
+  const logs = [];
+  page.on('console', msg => {
+    const text = msg.text();
+    logs.push(`${msg.type()}: ${text}`);
+    if (msg.type() === 'error') errors.push(text);
+  });
+  page.on('pageerror', err => errors.push(`pageerror: ${err.message}`));
+  await page.goto('http://127.0.0.1:3000/learn', {waitUntil:'domcontentloaded', timeout:30000});
+  await new Promise(r => setTimeout(r, 1200));
+  const fresh = await page.evaluate(() => ({
+    path: location.pathname,
+    h1: document.querySelector('h1')?.innerText || '',
+    cta: document.querySelector('a[href^="/missions/"]')?.textContent?.trim() || '',
+    body: document.body.innerText,
+    issueBadge: document.body.innerText.includes('Issue'),
+  }));
+  await page.click('a[href^="/missions/"]');
+  await new Promise(r => setTimeout(r, 800));
+  const afterClick = await page.evaluate(() => ({path: location.pathname, h1: document.querySelector('h1')?.innerText || ''}));
+  await page.goto('http://127.0.0.1:3000/learn', {waitUntil:'domcontentloaded', timeout:30000});
+  await page.evaluate(() => localStorage.setItem('adipoli:module1:completedMissions', JSON.stringify(['greetFrauWeber','politeExit'])));
+  await page.reload({waitUntil:'domcontentloaded', timeout:30000});
+  await new Promise(r => setTimeout(r, 800));
+  const module2 = await page.evaluate(() => ({
+    path: location.pathname,
+    h1: document.querySelector('h1')?.innerText || '',
+    cta: document.querySelector('a[href^="/missions/"]')?.textContent?.trim() || '',
+    text: document.body.innerText,
+  }));
+  await page.click('a[href^="/missions/"]');
+  await new Promise(r => setTimeout(r, 800));
+  const afterM2Click = await page.evaluate(() => ({path: location.pathname, h1: document.querySelector('h1')?.innerText || ''}));
+  console.log(JSON.stringify({fresh, afterClick, module2, afterM2Click, errors, logs: logs.slice(0,20)}, null, 2));
+  await browser.close();
+  if (errors.some(e => /Hydration failed|Error|pageerror/i.test(e))) process.exit(2);
+})();
