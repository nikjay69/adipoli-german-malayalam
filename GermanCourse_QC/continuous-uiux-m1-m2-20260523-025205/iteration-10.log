+import puppeteer from 'puppeteer';
+
+const BASE_URL = process.env.ADIPOLI_BASE_URL || 'http://127.0.0.1:3000';
+const CHROME = process.env.PUPPETEER_EXECUTABLE_PATH || '/usr/bin/google-chrome';
+const STORAGE_KEYS = [
+  'german-course-storage',
+  'adipoli:module1:completedMissions',
+  'adipoli:module2:completedMissions',
+];
+
+const delay = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
+
+function fail(message, details = {}) {
+  console.error(`FAIL: ${message}`);
+  if (Object.keys(details).length) console.error(JSON.stringify(details, null, 2));
+  process.exit(1);
+}
+
+function assert(condition, message, details = {}) {
+  if (!condition) fail(message, details);
+}
+
+async function pageState(page) {
+  return page.evaluate(() => ({
+    path: window.location.pathname,
+    text: document.body.innerText,
+    buttons: Array.from(document.querySelectorAll('button')).map((button) => button.innerText.trim()).filter(Boolean),
+    links: Array.from(document.querySelectorAll('a[href]')).map((link) => ({
+      text: link.textContent?.trim() ?? '',
+      href: link.getAttribute('href'),
+    })),
+  }));
+}
+
+const browser = await puppeteer.launch({
+  headless: 'new',
+  executablePath: CHROME,
+  args: ['--no-sandbox', '--disable-setuid-sandbox'],
+  defaultViewport: { width: 390, height: 844, isMobile: true },
+});
+
+try {
+  const page = await browser.newPage();
+  const consoleErrors = [];
+  page.on('console', (msg) => {
+    if (msg.type() === 'error') consoleErrors.push(msg.text());
+  });
+  page.on('pageerror', (err) => consoleErrors.push(err.message));
+
+  await page.evaluateOnNewDocument((keys) => {
+    for (const key of keys) window.localStorage.removeItem(key);
+  }, STORAGE_KEYS);
+
+  await page.goto(`${BASE_URL}/intro`, { waitUntil: 'domcontentloaded', timeout: 45000 });
+  await delay(700);
+  let state = await pageState(page);
+
+  assert(state.path === '/intro', 'intro did not load on /intro', state);
+  assert(state.text.includes('Start with one real German win.'), 'single-screen intro headline missing', { text: state.text.slice(0, 700) });
+  assert(state.text.includes('No dashboard wandering. Open the first guided classroom mission.'), 'intro context sentence missing', { text: state.text.slice(0, 700) });
+  assert(state.text.includes('Guten Morgen. Ich lerne Deutsch.'), 'intro phrase preview missing', { text: state.text.slice(0, 700) });
+  assert(state.buttons.length === 1 && state.buttons[0].includes('Open first mission'), 'intro should expose exactly one primary CTA', state);
+  assert(!state.text.includes('What happens next'), 'old middle intro slide still visible', { text: state.text.slice(0, 700) });
+
+  await page.click('button');
+  await page.waitForFunction(() => window.location.pathname === '/learn', { timeout: 10000 });
+  await delay(700);
+  state = await pageState(page);
+  assert(state.path === '/learn', 'intro CTA did not route to /learn', state);
+  assert(state.text.includes('Module 1') && state.text.includes('Mission 1.1'), '/learn did not open on the Module 1 guided mission lane', { text: state.text.slice(0, 900) });
+
+  const missionHref = await page.evaluate(() => {
+    const links = Array.from(document.querySelectorAll('a[href]'));
+    const missionLink = links.find((link) => link.getAttribute('href') === '/missions/module-1/greet-frau-weber');
+    missionLink?.click();
+    return missionLink?.getAttribute('href') ?? null;
+  });
+  assert(missionHref === '/missions/module-1/greet-frau-weber', '/learn primary Module 1 mission link missing', state);
