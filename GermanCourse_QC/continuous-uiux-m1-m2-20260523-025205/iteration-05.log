+
+  const builtThanks = selectedWords.join(' ');
+  const builderCorrect = builtThanks === correctThanks;
+  const recognitionCorrect = recognition === 'danke';
+  const typedNormalized = normalizeMissionAnswer(typedAnswer);
+  const typedIsStrong = typedNormalized.includes('danke') && typedNormalized.includes('bitte');
+  const repairCorrect = repairChoice === 'danke';
+
+  useEffect(() => {
+    if (step === missionSteps.length - 1) {
+      writeCompletedModule1Mission(mission.id);
+    }
+  }, [step]);
+
+  const canContinue = useMemo(() => {
+    switch (step) {
+      case 1:
+        return heard;
+      case 2:
+        return recognitionCorrect;
+      case 3:
+        return builderCorrect;
+      case 4:
+        return spokenChecked && typedIsStrong;
+      case 5:
+        return repairCorrect;
+      default:
+        return true;
+    }
+  }, [builderCorrect, heard, recognitionCorrect, repairCorrect, spokenChecked, step, typedIsStrong]);
+
