+];
+
+const builderWords = ['Danke', 'Bitte'];
+const builderBank = ['Danke', 'Bitte', 'Tschüss', 'Gute', 'Nacht'];
+const correctThanks = 'Danke Bitte';
+
+export default function Module1PleaseThanksMissionPage() {
+  const [step, setStep] = useMissionStepForQA(0, missionSteps.length - 1);
